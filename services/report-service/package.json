{
    "name": "@placenxt/report-service",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "cd ../../packages/shared && tsc && cd ../../services/report-service && npx prisma generate --schema=../../packages/database/prisma/schema.prisma && tsc",
        "prestart": "npm run build",
        "start": "node dist/index.js",
        "test": "jest"
    },
    "dependencies": {
        "@prisma/client": "^5.7.0",
        "@placenxt/shared": "*",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "winston": "^3.11.0",
        "zod": "^3.22.4",
        "pdfkit": "^0.15.0",
        "exceljs": "^4.4.0",
        "@types/pdfkit": "^0.13.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "prisma": "^5.7.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "jest": "^29.7.0",
        "@types/jest": "^29.5.11",
        "ts-jest": "^29.1.1"
    }
}