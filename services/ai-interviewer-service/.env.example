# ============================================
# AI INTERVIEWER SERVICE — Environment Config
# ============================================
# Copy to .env and fill in values

PORT=3016
NODE_ENV=development

# ── Database ────────────────────────────────
DATABASE_URL=postgresql://placenxt:placenxt123@localhost:5432/placenxt_db

# ── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Internal Service URLs ───────────────────
MEDIA_SERVICE_URL=http://localhost:3014
INTERVIEW_SERVICE_URL=http://localhost:3007

# ── Internal Auth (service-to-service) ──────
INTERNAL_SERVICE_SECRET=internal-secret

# ── AI Models ───────────────────────────────
# Groq — question generation (fast LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — Text-to-Speech (tts-1 model)
OPENAI_API_KEY=your_openai_api_key_here
TTS_MODEL=tts-1
TTS_VOICE=nova

# ── AI Interview Config ──────────────────────
# Max questions per phase before advancing
MAX_INTRO_QUESTIONS=2
MAX_TECHNICAL_QUESTIONS=5
MAX_BEHAVIORAL_QUESTIONS=3
MAX_WRAPUP_QUESTIONS=1

# Silence threshold before AI prompts (seconds)
SILENCE_THRESHOLD_SECONDS=8

# ── CORS ────────────────────────────────────
CORS_ORIGIN=http://localhost:3100
